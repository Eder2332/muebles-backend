PORT=3000

# Local Postgres (cuando NO uses Supabase)
DB_NAME=muebles_db
DB_USER=eder_user
DB_PASSWORD=tu_password_local
DB_HOST=localhost
DB_PORT=5432

# Supabase (cuando SÍ uses Supabase): pega aquí tu URI real
# DATABASE_URL=postgresql://postgres:TU_PASSWORD@db.TU_REF.supabase.co:5432/postgres

JWT_SECRET=pon_un_secret_largo_aqui

# CORS (separado por comas). Ejemplos:
# CORS_ORIGINS=https://tu-front.vercel.app,https://tu-dominio.com
# En local ya se permite http://localhost:3000 y http://127.0.0.1:3000 por defecto.
CORS_ORIGINS=
